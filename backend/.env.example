# UX Guardian Backend Environment Config

# Database
DATABASE_URL=sqlite:///./sqlite.db

# Authentication
# Replace this with a secure random key in production!
SECRET_KEY=yoursecretkeyhere12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Provider Configuration
# Set to 'gemini' or 'openai'
LLM_PROVIDER=gemini

# Gemini Configuration (Recommended for high free tier limits)
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Configuration (Requires a funded billing account)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4o
